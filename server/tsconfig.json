{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node16",
        "noImplicitAny": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "types": ["node"],
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": ["src"],
    "exclude": [ "node_modules","dist"]
}